---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const t = translations[lang].work;
---

<section id="work" class="work">
  <div class="container">
    <div class="work__header">
      <div>
        <span class="tag">{t.tag}</span>
        <div class="divider"></div>
        <h2 class="work__title">
          {t.titleLine1}<br />
          <em class="gradient-text">{t.titleLine2}</em>
        </h2>
      </div>
      <p class="work__subtitle">
        {t.subtitle.split('\n').map((line, i, arr) => (
          i < arr.length - 1 ? <>{line}<br /></> : line
        ))}
      </p>
    </div>

    <div class="work__list">
      {t.items.map((p) => (
        <div class="work-item" data-color={p.color}>
          <div class="work-item__left">
            <span class="work-item__num">{p.id}</span>
          </div>
          <div class="work-item__center">
            <div class="work-item__meta">
              <h3 class="work-item__title">{p.title}</h3>
              <span class={`work-item__badge work-item__badge--${p.type}`}>
                {p.type === 'education' ? t.badgeEdu : t.badgeExp}
              </span>
            </div>
            <p class="work-item__desc">{p.description}</p>
          </div>
          <div class="work-item__right">
            <span class="work-item__cat">{p.category}</span>
            <span class="work-item__year">{p.year}</span>
          </div>
          <div class="work-item__preview" style={`background: linear-gradient(135deg, ${p.color}22, ${p.color}44)`}>
            <div class="work-item__preview-inner" style={`color: ${p.color}`}>
              {p.title.split(' ').map((w: string) => w[0]).join('')}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="work__footer">
      <a href="#contact" class="btn btn-outline"><span>{t.cta}</span></a>
    </div>
  </div>
</section>

<style>
.work__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: clamp(3rem, 6vw, 6rem);
  flex-wrap: wrap;
  gap: 2rem;
}

.work__title { margin: 1.5rem 0 0; color: var(--clr-white); }
.work__title em { font-style: italic; }

.work__subtitle { max-width: 260px; text-align: right; line-height: 1.7; }

.work__list { border-top: 1px solid var(--clr-border); }

.work-item {
  display: grid;
  grid-template-columns: 60px 1fr auto;
  align-items: center;
  gap: 2rem;
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--clr-border);
  cursor: pointer;
  position: relative;
  transition: padding-left 0.4s var(--ease-out);
  overflow: hidden;
}

.work-item::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--clr-accent);
  transform: scaleY(0);
  transition: transform 0.4s var(--ease-out);
}

.work-item:hover { padding-left: 1.5rem; }
.work-item:hover::before { transform: scaleY(1); }

.work-item__preview {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 200px;
  opacity: 0;
  transition: opacity 0.4s var(--ease-out);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.work-item__preview-inner {
  font-family: var(--font-display);
  font-size: 3.5rem;
  font-weight: 300;
  opacity: 0.3;
  letter-spacing: 0.1em;
}

.work-item:hover .work-item__preview { opacity: 1; }

.work-item__left { display: flex; align-items: center; justify-content: center; }

.work-item__num {
  font-family: var(--font-display);
  font-size: 0.85rem;
  color: var(--clr-text-dim);
  letter-spacing: 0.1em;
  transition: color 0.3s ease;
}

.work-item:hover .work-item__num { color: var(--clr-accent); }

.work-item__meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}

.work-item__title {
  font-size: clamp(1.1rem, 2.2vw, 1.8rem);
  font-weight: 300;
  color: var(--clr-white);
  margin: 0;
  transition: color 0.3s ease;
}

.work-item:hover .work-item__title { color: var(--clr-purple-pale); }

.work-item__badge {
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.25rem 0.6rem;
  white-space: nowrap;
}

.work-item__badge--experience {
  background: rgba(61, 127, 255, 0.10);
  color: var(--clr-accent);
  border: 1px solid rgba(61, 127, 255, 0.28);
}

.work-item__badge--education {
  background: rgba(109, 191, 128, 0.1);
  color: #6dbf80;
  border: 1px solid rgba(109, 191, 128, 0.3);
}

.work-item__desc {
  font-size: 0.85rem;
  color: var(--clr-text-dim);
  max-width: 500px;
  line-height: 1.6;
  opacity: 0;
  transform: translateY(6px);
  transition: all 0.4s var(--ease-out);
}

.work-item:hover .work-item__desc { opacity: 1; transform: translateY(0); }

.work-item__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.4rem;
  z-index: 1;
  min-width: 0;
}

.work-item__cat {
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--clr-text-muted);
  text-align: right;
}

.work-item__year {
  font-family: var(--font-display);
  font-size: 0.9rem;
  color: var(--clr-text-dim);
  white-space: nowrap;
}

.work__footer { margin-top: 4rem; display: flex; justify-content: center; }

@media (max-width: 768px) {
  .work-item {
    grid-template-columns: 36px 1fr;
    gap: 1rem;
    padding: 1.75rem 0;
  }
  .work-item__right {
    grid-column: 2;
    align-items: flex-start;
    flex-direction: row;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .work__subtitle { text-align: left; }
  .work-item__preview { display: none; }
}

@media (max-width: 600px) {
  .work__header { flex-direction: column; align-items: flex-start; }
  .work-item { grid-template-columns: 1fr; padding: 1.5rem 0; }
  .work-item__left { display: none; }
  .work-item__right { grid-column: 1; flex-direction: row; gap: 0.75rem; margin-top: 0.5rem; }
  .work-item__cat { font-size: 0.65rem; }
}
</style>
