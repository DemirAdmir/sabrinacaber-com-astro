---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const t = translations[lang].about;
---

<section id="about" class="about">
  <div class="about__bg-orb" aria-hidden="true"></div>
  <div class="container">
    <div class="about__grid">
      <!-- Left: visual -->
      <div class="about__visual">
        <div class="about__image-wrapper">
          <div class="about__image-frame"></div>
          <div class="about__image-placeholder">
            <img src="/sabrina.png" alt="Sabrina Caber" class="about__photo" />
          </div>
          <div class="about__image-accent"></div>
        </div>
        <div class="about__stats">
          {t.stats.map((s) => (
            <div class="about__stat">
              <span class="about__stat-num">{s.num}</span>
              <span class="about__stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: content -->
      <div class="about__content">
        <p class="about__overline tag">{t.tag}</p>
        <div class="divider"></div>
        <h2 class="about__title">
          {t.titleLine1}<br />
          <em>{t.titleLine2}</em>
        </h2>
        <p class="about__body">{t.body1}</p>
        <p class="about__body">{t.body2}</p>
        <p class="about__note">{t.note}</p>
        <div class="about__skills">
          {t.skills.map((s) => <span class="tag">{s}</span>)}
        </div>
        <a href="#contact" class="btn btn-outline about__cta">
          <span>{t.cta}</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.about { overflow: hidden; clip-path: inset(0); }

.about__bg-orb {
  position: absolute;
  top: -150px;
  right: 0;
  transform: translateX(30%);
  width: clamp(300px, 50vw, 500px);
  height: clamp(300px, 50vw, 500px);
  border-radius: 50%;
  background: radial-gradient(circle, rgba(35, 80, 150, 0.12) 0%, transparent 70%);
  pointer-events: none;
}

.about__grid {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: clamp(3rem, 8vw, 8rem);
  align-items: center;
}

.about__grid > * { min-width: 0; }

.about__visual { display: flex; flex-direction: column; gap: 3rem; }

.about__image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  max-width: 260px;
}

.about__image-placeholder {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--clr-surface) 0%, var(--clr-surface-2) 100%);
  border: 1px solid var(--clr-border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.about__photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.about__image-frame {
  position: absolute;
  top: -16px; left: -16px; right: 16px; bottom: 16px;
  border: 1px solid var(--clr-border);
  pointer-events: none;
  z-index: -1;
}

.about__image-accent {
  position: absolute;
  bottom: -24px; right: -24px;
  width: 100px; height: 100px;
  border-bottom: 2px solid var(--clr-accent);
  border-right: 2px solid var(--clr-accent);
}

.about__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.about__stat {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 1.25rem;
  border: 1px solid var(--clr-border);
  background: var(--clr-surface);
  position: relative;
  overflow: hidden;
}

.about__stat::before {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 0; height: 1px;
  background: var(--clr-accent);
  transition: width 0.6s var(--ease-out);
}

.about__stat:hover::before { width: 100%; }

.about__stat-num {
  font-family: var(--font-display);
  font-size: 2.2rem;
  font-weight: 300;
  color: var(--clr-purple-pale);
  line-height: 1;
}

.about__stat-label {
  font-size: 0.65rem;
  letter-spacing: 0.05em;
  color: var(--clr-text-dim);
  text-transform: uppercase;
}

.about__overline { margin-bottom: 0; }

.about__title { margin: 1.5rem 0; color: var(--clr-white); }
.about__title em { font-style: italic; color: var(--clr-accent); }

.about__body { margin-bottom: 1.5rem; line-height: 1.85; }

.about__note {
  font-size: 0.82rem;
  color: var(--clr-text-dim);
  font-style: italic;
  border-left: 2px solid var(--clr-purple-mid);
  padding-left: 1rem;
  margin-bottom: 2rem;
  line-height: 1.6;
}

.about__skills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 2rem 0; }
.about__cta { margin-top: 0.5rem; }

@media (max-width: 900px) {
  .about__grid { grid-template-columns: 1fr; }
  .about__image-wrapper { max-width: 200px; }
  .about__visual { flex-direction: row; align-items: flex-start; gap: 2rem; }
  .about__stats { grid-template-columns: 1fr; flex: 1; }
}

@media (max-width: 700px) {
  .about__visual { flex-direction: column; }
  .about__image-wrapper { max-width: 100%; aspect-ratio: 4/3; overflow: hidden; }
  .about__image-frame { display: none; }
  .about__image-accent { display: none; }
}

@media (max-width: 600px) {
  .about__stats { grid-template-columns: repeat(3, 1fr); gap: 0.4rem; }
  .about__stat { padding: 0.9rem 0.6rem; }
  .about__stat-num { font-size: 1.4rem; }
  .about__stat-label { font-size: 0.55rem; letter-spacing: 0.03em; }
}
</style>
