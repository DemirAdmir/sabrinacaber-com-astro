---
import { translations, type Lang } from '../i18n/translations';
interface Props { lang?: Lang; }
const { lang = 'en' } = Astro.props;
const t = translations[lang].hero;
---

<section id="home" class="hero">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <div class="hero__content container">
    <div class="hero__eyebrow fade-up">
      <span class="tag">{t.tag1}</span>
      <span class="tag">{t.tag2}</span>
    </div>

    <h1 class="hero__title fade-up">
      <span class="hero__title-line">{t.titleLine1}</span>
      <span class="hero__title-line hero__title-accent gradient-text">{t.titleLine2}</span>
    </h1>

    <p class="hero__subtitle fade-up">{t.subtitle}</p>

    <div class="hero__actions fade-up">
      <a href="#services" class="btn btn-primary"><span>{t.cta1}</span></a>
      <a href="#about" class="btn btn-outline"><span>{t.cta2}</span></a>
    </div>

    <div class="hero__scroll-indicator fade-in">
      <div class="hero__scroll-line"></div>
      <span>{t.scroll}</span>
    </div>
  </div>

  <div class="hero__marquee" aria-hidden="true">
    <div class="hero__marquee-track">
      {[...t.marquee, ...t.marquee].map((item) => (
        <>{item}<span class="sep">◆</span></>
      ))}
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding-top: 100px;
}

#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

@media (max-width: 900px) {
  #hero-canvas { opacity: 0.45; }
}

.hero__content {
  position: relative;
  z-index: 2;
  max-width: 820px;
  padding-bottom: 8rem;
}

.hero__eyebrow {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  width: 100%;
  overflow: hidden;
}

.hero__title { margin-bottom: 2rem; }

.hero__title-line {
  display: block;
  letter-spacing: -0.02em;
}

.hero__title-accent {
  font-style: italic;
  font-weight: 400;
}

.hero__subtitle {
  font-size: clamp(0.95rem, 1.4vw, 1.05rem);
  color: var(--clr-text-muted);
  margin-bottom: 3rem;
  max-width: 540px;
  line-height: 1.8;
}

.hero__actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.hero__scroll-indicator {
  position: absolute;
  bottom: 3rem;
  left: clamp(20px, 5vw, 60px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.hero__scroll-line {
  width: 1px;
  height: 56px;
  background: linear-gradient(to bottom, var(--clr-accent), transparent);
  animation: scrollPulse 2.5s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { transform: scaleY(1); opacity: 0.8; }
  50% { transform: scaleY(0.5); opacity: 0.25; }
}

.hero__scroll-indicator span {
  font-size: 0.6rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--clr-text-dim);
  writing-mode: vertical-rl;
}

.hero__marquee {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  overflow: hidden;
  border-top: 1px solid var(--clr-border);
  background: rgba(7, 16, 28, 0.7);
  backdrop-filter: blur(12px);
  padding: 0.9rem 0;
}

.hero__marquee-track {
  display: flex;
  gap: 2rem;
  width: max-content;
  animation: marquee 32s linear infinite;
}

.hero__marquee-track span,
.hero__marquee-track :global(span) {
  font-size: 0.68rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--clr-text-dim);
  white-space: nowrap;
}

.hero__marquee-track .sep,
.hero__marquee-track :global(.sep) {
  color: var(--clr-purple-mid);
  letter-spacing: 0;
}

@keyframes marquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

@media (max-width: 768px) {
  .hero__title { font-size: clamp(2.2rem, 8vw, 3.5rem); }
}

@media (max-width: 600px) {
  .hero__scroll-indicator { display: none; }
  .hero__content { padding-bottom: 6rem; }
  .hero__subtitle { font-size: 0.92rem; }
  .hero__actions { gap: 0.75rem; }
  .hero__actions .btn { padding: 0.8rem 1.5rem; font-size: 0.72rem; }
  .hero__eyebrow { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  .hero__title { font-size: clamp(2rem, 9vw, 2.8rem); }
  .hero__title-line { word-break: break-word; }
}
</style>

<script>
import * as THREE from 'three';
import { gsap } from 'gsap';

// ─── Renderer ────────────────────────────────────────────────
const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);

const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(44, window.innerWidth / window.innerHeight, 0.1, 100);
camera.position.set(0, 0, 7.5);

// ─── Globe Group ─────────────────────────────────────────────
const globeGroup = new THREE.Group();
globeGroup.rotation.z = 0.38; // axial tilt, like Earth
scene.add(globeGroup);

const R = 2.1; // globe radius
const BG_COLOR = 0x07101c; // matches --clr-bg

function updateGlobeLayout() {
  if (window.innerWidth > 900) {
    globeGroup.position.x = 2.2;
    globeGroup.position.y = 0;
  } else {
    globeGroup.position.x = 0;
    globeGroup.position.y = -0.3;
  }
}
updateGlobeLayout();

// ─── Occluder: solid sphere to hide back-side elements ───────
const occluder = new THREE.Mesh(
  new THREE.SphereGeometry(R * 0.982, 36, 26),
  new THREE.MeshBasicMaterial({ color: BG_COLOR })
);
globeGroup.add(occluder);

// ─── Wireframe grid ──────────────────────────────────────────
const wireGeo = new THREE.SphereGeometry(R, 42, 28);
const wireMat = new THREE.MeshBasicMaterial({
  color: 0x1e3d72,
  wireframe: true,
  transparent: true,
  opacity: 0.10,
});
globeGroup.add(new THREE.Mesh(wireGeo, wireMat));

// ─── Atmospheric halo ─────────────────────────────────────────
const haloGeo = new THREE.SphereGeometry(R * 1.14, 32, 24);
const haloMat = new THREE.MeshBasicMaterial({
  color: 0x1a4a8c,
  transparent: true,
  opacity: 0.04,
  side: THREE.BackSide,
  depthWrite: false,
});
globeGroup.add(new THREE.Mesh(haloGeo, haloMat));

// ─── Surface nodes ───────────────────────────────────────────
const NODE_COUNT = 190;
const nodePositions: THREE.Vector3[] = [];
const nodePosArr = new Float32Array(NODE_COUNT * 3);

for (let i = 0; i < NODE_COUNT; i++) {
  const theta = Math.random() * Math.PI * 2;
  const phi   = Math.acos(2 * Math.random() - 1);
  const x = R * Math.sin(phi) * Math.cos(theta);
  const y = R * Math.cos(phi);
  const z = R * Math.sin(phi) * Math.sin(theta);
  nodePositions.push(new THREE.Vector3(x, y, z));
  nodePosArr[i * 3]     = x;
  nodePosArr[i * 3 + 1] = y;
  nodePosArr[i * 3 + 2] = z;
}

const nodeGeo = new THREE.BufferGeometry();
nodeGeo.setAttribute('position', new THREE.BufferAttribute(nodePosArr, 3));
const nodeMat = new THREE.PointsMaterial({
  color: 0x4f8ef7,
  size: 0.04,
  transparent: true,
  opacity: 0.85,
  sizeAttenuation: true,
});
globeGroup.add(new THREE.Points(nodeGeo, nodeMat));

// ─── Arc connections ─────────────────────────────────────────
const ARC_COUNT = 22;

interface ArcData {
  curve: THREE.QuadraticBezierCurve3;
  progress: number;
  speed: number;
  dot: THREE.Mesh;
}

const arcData: ArcData[] = [];

for (let i = 0; i < ARC_COUNT; i++) {
  let ai = Math.floor(Math.random() * NODE_COUNT);
  let bi = Math.floor(Math.random() * NODE_COUNT);
  while (bi === ai) bi = Math.floor(Math.random() * NODE_COUNT);

  const a = nodePositions[ai];
  const b = nodePositions[bi];

  // Control point: midpoint direction elevated above sphere surface
  const ctrl = new THREE.Vector3()
    .addVectors(a, b)
    .normalize()
    .multiplyScalar(R + R * (0.3 + Math.random() * 0.55));

  const curve = new THREE.QuadraticBezierCurve3(a.clone(), ctrl, b.clone());
  const pts   = curve.getPoints(80);

  // Arc line
  const lineGeo = new THREE.BufferGeometry().setFromPoints(pts);
  const lineMat = new THREE.LineBasicMaterial({
    color: 0x2a5aab,
    transparent: true,
    opacity: 0.14 + Math.random() * 0.14,
  });
  globeGroup.add(new THREE.Line(lineGeo, lineMat));

  // Traveling dot
  const dotGeo = new THREE.SphereGeometry(0.026, 7, 7);
  const dotMat = new THREE.MeshBasicMaterial({
    color: 0xaad0ff,
    transparent: true,
    opacity: 0,
  });
  const dot = new THREE.Mesh(dotGeo, dotMat);
  globeGroup.add(dot);

  arcData.push({
    curve,
    progress: Math.random(),
    speed: 0.0022 + Math.random() * 0.0035,
    dot,
  });
}

// ─── Mouse parallax ──────────────────────────────────────────
let mouseX = 0, mouseY = 0;
let targetX = 0, targetY = 0;

document.addEventListener('mousemove', (e) => {
  targetX = (e.clientX / window.innerWidth - 0.5) * 2;
  targetY = (e.clientY / window.innerHeight - 0.5) * 2;
});

// ─── Resize ──────────────────────────────────────────────────
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
  updateGlobeLayout();
});

// ─── Animation loop ──────────────────────────────────────────
const clock = new THREE.Clock();

function animate() {
  requestAnimationFrame(animate);
  const elapsed = clock.getElapsedTime();

  // Smooth mouse tracking
  mouseX += (targetX - mouseX) * 0.035;
  mouseY += (targetY - mouseY) * 0.035;

  // Globe rotation: steady spin + mouse tilt
  globeGroup.rotation.y = elapsed * 0.072;
  globeGroup.rotation.x = mouseY * 0.12;

  // Subtle camera parallax
  camera.position.x += (mouseX * 0.35 - camera.position.x) * 0.04;
  camera.position.y += (-mouseY * 0.22 - camera.position.y) * 0.04;
  camera.lookAt(scene.position);

  // Update traveling particles
  arcData.forEach((arc) => {
    arc.progress += arc.speed;
    if (arc.progress > 1) arc.progress = 0;

    const pos = arc.curve.getPoint(arc.progress);
    arc.dot.position.copy(pos);

    // Fade in/out near endpoints
    const fade = Math.sin(arc.progress * Math.PI);
    (arc.dot.material as THREE.MeshBasicMaterial).opacity = fade * 0.92;
  });

  renderer.render(scene, camera);
}
animate();

// ─── GSAP entrance ───────────────────────────────────────────
gsap.set('.fade-up', { opacity: 0, y: 40 });
gsap.set('.fade-in', { opacity: 0 });

const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
tl.to('.hero__eyebrow',        { opacity: 1, y: 0, duration: 0.9, delay: 0.5 })
  .to('.hero__title-line',     { opacity: 1, y: 0, duration: 1,   stagger: 0.2 }, '-=0.5')
  .to('.hero__subtitle',       { opacity: 1, y: 0, duration: 0.9 }, '-=0.5')
  .to('.hero__actions',        { opacity: 1, y: 0, duration: 0.8 }, '-=0.4')
  .to('.hero__scroll-indicator', { opacity: 1, duration: 0.8 }, '-=0.2');

// Pause marquee on hover
const marquee = document.querySelector('.hero__marquee-track') as HTMLElement | null;
if (marquee) {
  marquee.addEventListener('mouseenter', () => { marquee.style.animationPlayState = 'paused'; });
  marquee.addEventListener('mouseleave', () => { marquee.style.animationPlayState = 'running'; });
}
</script>
